<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<suite name="OrangeHRM - UI automation test" parallel="tests" thread-count="3">
    <parameter name="webUrl" value="product"></parameter>
    <parameter name="environment" value="product"></parameter>

    <listeners>
        <listener class-name="core.MethodListener"></listener>
        <listener class-name="reportConfig.AllureTestListener"></listener>
<!--        <listener class-name="jiraConfigs.JiraListener"></listener>-->
    </listeners>

    <test name="Run on Chrome browser">
        <parameter name="browser" value="CHROME"></parameter>
        <classes>
            <class name="orangehrm.Login_31_Parallel_Testing"/>
        </classes>
    </test>

    <test name="Run on firefox browser">
        <parameter name="browser" value="firefox"></parameter>
        <classes>
            <class name="orangehrm.Login_31_Parallel_Testing"/>
        </classes>
    </test>

    <test name="Run on edge browser">
        <parameter name="browser" value="edge"></parameter>
        <classes>
            <class name="orangehrm.Login_31_Parallel_Testing"/>
        </classes>
    </test>
</suite>